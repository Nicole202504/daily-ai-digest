  {
    "id": "builder_blog:builder_blog:https://simonwillison.net/2026/Jul/6/sqlite-utils/#atom-everything",
    "source": "builder_blog",
    "sourceItemId": "builder_blog:https://simonwillison.net/2026/Jul/6/sqlite-utils/#atom-everything",
