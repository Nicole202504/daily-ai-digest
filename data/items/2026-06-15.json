  {
    "id": "builder_blog:builder_blog:https://simonwillison.net/2026/Jun/15/julia-evans/#atom-everything",
    "source": "builder_blog",
    "sourceItemId": "builder_blog:https://simonwillison.net/2026/Jun/15/julia-evans/#atom-everything",
